# someone.help — environment variables

# Together AI inference key (from https://api.together.ai).
TOGETHER_API_KEY=

# Model id from Together AI catalog. Llama 3.3 70B Instruct Turbo is the default.
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Per-UUID daily token soft cap. Hard cap lives at the provider account level.
DAILY_TOKEN_LIMIT_PER_UUID=50000

# Per-UUID per-minute message cap (in-memory, not durable across deploys).
MESSAGES_PER_MINUTE_PER_UUID=20

# Optional aggregate page analytics (e.g. Umami). Set BOTH in your host’s secret
# env — do not commit real URLs or IDs to a public repo. Omit either to disable.
# NEXT_PUBLIC_UMAMI_SCRIPT_URL=
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Trust CF-Connecting-IP / forwarded client IP for in-memory rate limits only (not logged).
TRUST_CLOUDFLARE=false
